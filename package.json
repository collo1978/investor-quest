{
  "name": "investor-quest",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "start:local": "node scripts/dev-server.mjs",
    "dev:kill-port": "node scripts/kill-port.mjs 3003",
    "dev:3000": "next dev -p 3000",
    "dev:fresh": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){if(e.code!=='ENOENT')throw e}\" && node scripts/dev-server.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "optimize:screens": "node scripts/optimize-screen-images.mjs",
    "regenerate:demo-quests": "node scripts/regenerate-all-demo-quests.mjs",
    "generate:handoff-pdf": "node scripts/generate-handoff-pdf.mjs",
    "cap:sync": "npx cap sync",
    "cap:sync:local": "cross-env CAPACITOR_SERVER_URL=http://localhost:3003/schools/demo npx cap sync",
    "cap:sync:android-local": "cross-env CAPACITOR_SERVER_URL=http://10.0.2.2:3003/schools/demo npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@react-three/fiber": "^9.6.1",
    "@shikijs/transformers": "^4.3.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cobe": "^0.6.5",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.0",
    "next": "^15.4.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-tweet": "^3.3.1",
    "rough-notation": "^0.5.1",
    "shiki": "^4.3.0",
    "svg-dotted-map": "^2.0.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.185.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.4.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "postcss": "^8.5.6",
    "puppeteer": "^25.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.10",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3"
  }
