{
  "name": "investor-quest",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "dev:kill-port": "node scripts/kill-port.mjs 3003",
    "dev:3000": "next dev -p 3000",
    "dev:fresh": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){if(e.code!=='ENOENT')throw e}\" && node scripts/dev-server.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "optimize:screens": "node scripts/optimize-screen-images.mjs",
    "regenerate:demo-quests": "node scripts/regenerate-all-demo-quests.mjs",
    "cap:sync": "npx cap sync",
    "cap:sync:local": "cross-env CAPACITOR_SERVER_URL=http://localhost:3003/schools/demo npx cap sync",
    "cap:sync:android-local": "cross-env CAPACITOR_SERVER_URL=http://10.0.2.2:3003/schools/demo npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "framer-motion": "^12.23.12",
    "next": "^15.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.4.0",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3"
  }
}
