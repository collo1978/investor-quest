{
  // Template — copy to %USERPROFILE%\.cursor\permissions.json (Cursor only reads the global file).
  // Prerequisite: Cursor Settings → Agent → Auto-run = "Auto-Run in Sandbox" (NOT "Ask Every Time").
  // Prefix matching only. Never add bare "git" or "npm" (would auto-approve commit/push/install/dev).
  "terminalAllowlist": [
    "rg",
    "grep",
    "findstr",
    "where.exe",
    "dir ",
    "tree ",
    "ls",
    "ls ",
    "pwd",
    "cd",
    "cd ",
    "echo ",
    "type ",
    "cat ",
    "Get-Location",
    "Set-Location",
    "Get-ChildItem",
    "Select-String",
    "Select-Object",
    "Where-Object",
    "Get-Content",
    "Test-Path",
    "git status",
    "git diff",
    "git log",
    "git show",
    "git branch",
    "git rev-parse",
    "git remote -v",
    "git config --get",
    "git config --list",
    "git stash list",
    "node --version",
    "npm --version",
    "npx tsc",
    "npx tsc --noEmit",
    "npm run lint",
    "npm run dev",
    "gh pr view",
    "gh pr list",
    "gh pr checks",
    "gh pr diff",
    "gh issue view",
    "gh issue list",
    "gh run view",
    "gh run list",
    "gh api ",
    "gh status"
  ]
}
